#!/usr/bin/env bash
set -Eeuo pipefail

WEB_DIR="${WEB_DIR:?WEB_DIR is required}"
SERVICE_DIR="${SERVICE_DIR:?SERVICE_DIR is required}"

cd "$SERVICE_DIR/cloudrun"
python3 -c 'from app import app; app.run(host="0.0.0.0", port=8080, debug=False, use_reloader=False)' &
backend_pid=$!

cd "$WEB_DIR"
npm run preview -- --host 0.0.0.0 --port 5173 --strictPort &
frontend_pid=$!

cleanup() {
  kill "$backend_pid" "$frontend_pid" 2>/dev/null || true
  wait "$backend_pid" "$frontend_pid" 2>/dev/null || true
}
trap cleanup EXIT INT TERM
wait -n "$backend_pid" "$frontend_pid"
